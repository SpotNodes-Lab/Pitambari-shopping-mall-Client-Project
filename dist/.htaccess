# Apache (e.g. Hostinger): SPA fallback so React Router paths work.
# Static files (assets, sitemap.xml, robots.txt, favicon.png) are served as-is.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
