# Pitambari CMS / homepage + public QR (see USER_WEB_API.md in monorepo root).
#
# LOCAL DEV (default): Vite proxies /api → Pitambari-backend (vite.config.ts).
VITE_API_URL=/api
#
# LOCAL without proxy (either form — /api is added automatically for http(s) URLs):
# VITE_API_URL=http://localhost:4000
# VITE_API_URL=http://localhost:4000/api
#
# PRODUCTION (Vercel, Netlify, etc.): REQUIRED. Static sites have no dev proxy — set the real API:
# VITE_API_URL=https://your-pitambari-backend.example.com/api
# Also set Pitambari-backend CORS_ORIGINS to include your storefront origin (or use * for testing).

# Rewards / loyalty server vars (see README.md) — separate from CMS.

# Contact form → Google Sheet via Apps Script Web App URL (ends in /exec).
# In scripts/google-apps-script-contact-form.gs set SPREADSHEET_ID from your sheet link:
# https://docs.google.com/spreadsheets/d/<ID>/edit
# Optional: overrides the built-in default Web App URL in ContactFormSection.tsx
# VITE_CONTACT_FORM_URL=https://script.google.com/macros/s/AKfycbyjFWr4uK7aNF8Ws4oVTTyyuzW7WExIK_8LtwiQoc2r_0tv-9Hsy5Cs8kj7f51FVIU4/exec

# Patron reviews modal → Google Apps Script Web App (see scripts/google-apps-script-patron-reviews.gs).
# Optional: overrides the default URL baked into TestimonialsSection.tsx.
# VITE_REVIEW_FORM_URL=https://script.google.com/macros/s/AKfycbzKteZDnu3TMYQXvR0J_TLO-4m4tinogeO_9-r8sAKE-CW8l7DFovhMpAjLU65_RJU1/exec
